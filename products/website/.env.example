# Variáveis do site Builders (Astro). Copie para .env e preencha quando aplicável.
# Tudo com prefixo PUBLIC_ fica exposto no cliente — não colocar segredos aqui.

# URL final do site (definir na Vercel quando o domínio estiver registrado).
# Sem isso, o sitemap e as URLs canônicas usam http://localhost:4321.
PUBLIC_SITE_URL=

# Tracking (opcional) — preencher quando os pixels existirem.
PUBLIC_GA_ID=
PUBLIC_META_PIXEL=
