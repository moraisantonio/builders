---
// Faixa "Atmosfera" — carrossel de fotos que mostra o jeito Builders:
// tecnologia, café e gente resolvendo junto. Marquee em loop (CSS puro).
// As fotos repetem (duas trilhas) para o loop ser contínuo.
const fotos = [
  { src: "/fotos/rolagem-1.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-2.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-3.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-4.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-5.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-6.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-7.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-8.jpg", alt: "Builders trabalhando" },
  { src: "/fotos/rolagem-9.jpg", alt: "Builders trabalhando" },
];
---

<section class="atmos">
  <div class="container atmos-head">
    <p class="eyebrow">Quem faz</p>
    <h2>Tecnologia no ritmo de quem resolve junto.</h2>
    <p class="atmos-lead">
      Café, código e gente por perto. A gente cuida do seu digital como se fosse
      da nossa turma — rápido, presente e sem complicar.
    </p>
  </div>

  <div class="atmos-marquee" aria-hidden="true">
    <div class="atmos-track">
      {fotos.map((f) => (
        <figure class="atmos-item"><img class="toned" src={f.src} alt={f.alt} loading="lazy" /></figure>
      ))}
      {fotos.map((f) => (
        <figure class="atmos-item"><img class="toned" src={f.src} alt="" loading="lazy" /></figure>
      ))}
    </div>
  </div>
</section>

<style>
  .atmos {
    background: var(--color-paper-white);
    padding: 96px 0;
    overflow: hidden;
  }
  .atmos-head {
    margin-bottom: 44px;
  }
  .atmos-head h2 {
    font-size: 34px;
    line-height: 1.2;
    color: var(--color-off-black);
    margin: 0 0 14px;
    max-width: 20ch;
  }
  .atmos-lead {
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-peacock);
    max-width: 52ch;
    margin: 0;
  }
  /* máscara nas pontas pra entrada/saída suave */
  .atmos-marquee {
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .atmos-track {
    display: flex;
    gap: 18px;
    width: max-content;
    animation: atmos-scroll 48s linear infinite;
  }
  .atmos:hover .atmos-track {
    animation-play-state: paused;
  }
  .atmos-item {
    margin: 0;
    flex: 0 0 auto;
    width: 320px;
    height: 230px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-ecru);
  }
  .atmos-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease);
  }
  .atmos-item:hover img {
    transform: scale(1.06);
  }
  @keyframes atmos-scroll {
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .atmos-track {
      animation: none;
    }
  }
  @media (max-width: 720px) {
    .atmos-head h2 {
      font-size: 26px;
    }
    .atmos-item {
      width: 240px;
      height: 175px;
    }
  }
</style>
