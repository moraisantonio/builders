---
// Dobra 5 — Sites que já fizemos (portfólio resumido).
const cases = [
  { tag: "Arquitetura", title: "Morá Arquitetura", bg: "linear-gradient(135deg, #133B39, #20808D)" },
  { tag: "drip · Cafeteria", title: "Café Origem", bg: "linear-gradient(135deg, #2E5E5A, #c8f06e)" },
  { tag: "Em breve", title: "Seu site aqui", bg: "linear-gradient(135deg, #E4E3D4, #FBFAF4)" },
];
---

<section class="cases" id="cases">
  <div class="container">
    <p class="eyebrow">Sites que já fizemos</p>
    <h2 class="section-title">A prova está no que a gente coloca no ar</h2>
    <div class="cases-grid">
      {
        cases.map((c) => (
          <article class="case-card">
            <div class="case-cover" style={`background:${c.bg}`} />
            <div class="case-body">
              <p class="case-tag">{c.tag}</p>
              <h3>{c.title}</h3>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cases {
    background: var(--color-paper-soft);
    padding: 112px 0;
  }
  .section-title {
    font-size: 36px;
    line-height: 1.2;
    color: var(--color-off-black);
    margin: 0 0 48px;
  }
  .cases-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }
  .case-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-ecru);
    background: #fff;
  }
  .case-cover {
    height: 180px;
  }
  .case-body {
    padding: 20px;
  }
  .case-tag {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-turquoise);
    margin: 0 0 8px;
  }
  .case-body h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-off-black);
    margin: 0;
  }
  @media (max-width: 720px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
    .section-title {
      font-size: 28px;
    }
  }
</style>
