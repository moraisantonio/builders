---
// Dobra 5 — Sites que já fizemos (portfólio).
// Cada card tem uma capa: imagem do site (quando há) ou gradiente da marca.
// Para trocar/colocar a imagem real de um site: jogue o arquivo em
// public/portfolio/<nome>.jpg e aponte `img` aqui.
// Portfólio: 4 cards lado a lado. Imagem do site em cada cliente;
// "Seu site aqui" fica branco com o "+".
const cases = [
  { tag: "Arquitetura", title: "Morá Arquitetura", img: "/portfolio/mora.jpg" },
  { tag: "IA · SaaS", title: "ArqVista", img: "/portfolio/arqvista.jpg" },
  { tag: "Cafeterias", title: "drip", img: "/portfolio/drip.jpg" },
  { tag: "Em breve", title: "Seu site aqui", bg: "#FFFFFF", soon: true },
];
---

<section class="cases" id="cases">
  <div class="container">
    <p class="eyebrow">Sites que já fizemos</p>
    <h2 class="section-title">A prova está no que a gente coloca no ar</h2>
    <div class="cases-grid">
      {
        cases.map((c) => (
          <article class={`case-card${c.soon ? " case-card--soon" : ""}`}>
            <div
              class="case-cover"
              style={
                c.img
                  ? `background-image: linear-gradient(180deg, rgba(9,23,23,0) 55%, rgba(9,23,23,.28)), url('${c.img}')`
                  : `background:${c.bg}`
              }
            >
              {c.soon && <span class="case-plus">+</span>}
            </div>
            <div class="case-body">
              <p class="case-tag">{c.tag}</p>
              <h3>{c.title}</h3>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cases {
    background: var(--color-paper-soft);
    padding: 112px 0;
  }
  .section-title {
    font-size: 36px;
    line-height: 1.2;
    color: var(--color-off-black);
    margin: 0 0 48px;
  }
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .case-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-ecru);
    background: #fff;
    transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
  }
  .case-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-turquoise);
    box-shadow: 0 18px 50px rgba(9, 23, 23, 0.12);
  }
  .case-cover {
    height: 200px;
    background-size: cover;
    background-position: center;
    transition: transform 0.6s var(--ease);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .case-card:hover .case-cover {
    transform: scale(1.04);
  }
  .case-card--soon .case-cover {
    border-bottom: 1px dashed var(--color-gray-light, #d8d8d2);
  }
  .case-plus {
    font-size: 34px;
    font-weight: 300;
    color: var(--color-turquoise);
    opacity: 0.6;
  }
  .case-body {
    padding: 20px;
  }
  .case-tag {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-turquoise);
    margin: 0 0 8px;
  }
  .case-body h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-off-black);
    margin: 0;
  }
  @media (max-width: 920px) {
    .cases-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .cases-grid {
      grid-template-columns: 1fr;
    }
    .section-title {
      font-size: 28px;
    }
  }
</style>
