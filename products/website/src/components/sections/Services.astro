---
// Dobra 3 — O que fazemos: 4 serviços em cards com foto (estilo bento).
// Cada serviço ganha uma imagem real + acento teal da marca.
const services = [
  {
    tag: "Sites",
    title: "Sites profissionais",
    desc: "Sites e landing pages que passam confiança, são fáceis de achar no Google e transformam visita em contato.",
    img: "/fotos/sites.jpg",
    alt: "Site profissional de cliente",
  },
  {
    tag: "Automação",
    title: "Automação & atendimento",
    desc: "WhatsApp, propostas e processos no automático — pra nada importante cair no esquecimento.",
    img: "/fotos/automacoes.jpg",
    alt: "Automação e atendimento em ação",
  },
  {
    tag: "IA",
    title: "Agentes de IA",
    desc: "Uma IA com a cara do seu negócio que atende, tira dúvidas e registra tudo, 24 horas por dia.",
    img: "/fotos/agentes-ia.png",
    alt: "Agente de IA do negócio",
  },
  {
    tag: "Plataforma",
    title: "Builders App",
    desc: "O painel onde você acompanha o digital e pede ajustes e novos serviços — sem contratar ninguém.",
    img: "/fotos/app-card.jpg",
    alt: "Builders App — painel do cliente",
  },
];
---

<section class="services" id="servicos">
  <div class="container">
    <p class="eyebrow">O que fazemos</p>
    <h2 class="section-title">Tudo que seu negócio precisa pra existir no digital</h2>
    <div class="services-grid">
      {
        services.map((s) => (
          <article class="service-card">
            <div class="service-media">
              <img class="toned" src={s.img} alt={s.alt} loading="lazy" />
              <span class="service-tag">{s.tag}</span>
            </div>
            <div class="service-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-paper-soft);
    padding: 112px 0;
  }
  .section-title {
    font-size: 36px;
    line-height: 1.2;
    color: var(--color-off-black);
    margin: 0 0 48px;
    max-width: 18ch;
  }
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .service-card {
    background: #fff;
    border: 1px solid var(--color-ecru);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.3s var(--ease), border-color 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }
  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-turquoise);
    box-shadow: 0 18px 50px rgba(9, 23, 23, 0.1);
  }
  .service-media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .service-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease);
  }
  .service-card:hover .service-media img {
    transform: scale(1.05);
  }
  /* leve véu teal sobre a foto — clima da marca */
  .service-media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(32, 128, 141, 0) 40%, rgba(9, 23, 23, 0.5));
    mix-blend-mode: multiply;
  }
  .service-tag {
    position: absolute;
    left: 14px;
    bottom: 12px;
    z-index: 2;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(32, 128, 141, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 5px 12px;
    border-radius: 999px;
    backdrop-filter: blur(4px);
  }
  .service-body {
    padding: 24px 26px 28px;
  }
  .service-body h3 {
    font-size: 19px;
    font-weight: 500;
    color: var(--color-off-black);
    margin: 0 0 8px;
  }
  .service-body p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-peacock);
    margin: 0;
  }
  @media (max-width: 720px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    .section-title {
      font-size: 28px;
    }
  }
</style>
