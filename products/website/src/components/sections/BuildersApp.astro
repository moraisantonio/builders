---
// Dobra 7 — Builders App: o painel do cliente.
const features = [
  "Chat com a IA do seu negócio",
  "Pedidos de ajuste e novos serviços",
  "Acompanhamento dos resultados",
  "Tudo o que a Builders cuida, num lugar só",
];
---

<section class="bapp" id="builders-app">
  <div class="container bapp-grid">
    <div class="bapp-col">
      <div class="bapp-intro">
        <p class="eyebrow eyebrow-lime">Builders App</p>
        <h2>O painel onde o seu digital vive.</h2>
        <p class="bapp-lead">
          Converse com a IA do seu negócio, acompanhe resultados, peça um site novo ou
          um ajuste — tudo num lugar só. Você no controle, sem depender de ninguém.
        </p>
      </div>
      <ul class="bapp-list">
        {features.map((f) => <li><span class="dot"></span>{f}</li>)}
      </ul>
    </div>
    <figure class="bapp-media">
      <img class="toned" src="/fotos/builders-app-dobra.jpg" alt="Site de cliente aberto no Builders App" loading="lazy" width="900" height="1200" />
    </figure>
  </div>
</section>

<style>
  .bapp {
    background: var(--color-inky-blue);
    padding: 112px 0;
  }
  .bapp-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
  }
  .bapp-col {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .bapp-intro {
    min-width: 280px;
  }
  .bapp-media {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(200, 240, 110, 0.08);
  }
  .bapp-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4 / 3;
  }
  .eyebrow-lime {
    color: var(--color-lime);
    margin-bottom: 16px;
  }
  .bapp-intro h2 {
    font-size: 34px;
    line-height: 1.2;
    color: var(--color-paper-white);
    margin: 0 0 20px;
  }
  .bapp-lead {
    font-size: 15px;
    line-height: 1.7;
    color: #a8d4d0;
    margin: 0;
  }
  .bapp-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .bapp-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius);
    padding: 16px 18px;
    font-size: 14px;
    color: var(--color-paper-white);
  }
  .bapp-list .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-lime);
    flex-shrink: 0;
  }
  @media (max-width: 860px) {
    .bapp-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .bapp-media {
      order: -1;
    }
  }
  @media (max-width: 720px) {
    .bapp-intro h2 {
      font-size: 26px;
    }
  }
</style>
