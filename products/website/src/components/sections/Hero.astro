---
// Dobra 1 — Hero. Altura controlada (não dependente do tamanho da imagem):
// céu em gradiente, headline branca no topo, o app emergindo da paisagem do Rio
// ancorada na base. Headline secundária + CTAs vêm depois da imagem.
import BrandIcon from "../BrandIcon.astro";

// Rótulos curtos pra caber na barra da janela do app, agrupados à esquerda.
const appTabs = ["Artefatos", "Reuniões", "Pagamentos", "Config."];
---

<section class="hero" aria-label="Apresentação">
  <div class="hero-scene">
    <!-- Frase principal sobre o céu -->
    <div class="hero-intro">
      <h1 class="hero-headline">
        Soluções para organizar e fortalecer sua
        <span class="hero-accent">presença digital</span>
      </h1>
    </div>

    <!-- App emergindo da paisagem (atrás do recorte, ancorado na base) -->
    <div class="hero-app" aria-hidden="true">
      <div class="hero-app-tabs">
        <div class="hero-app-brand">
          <BrandIcon size={12} color="#20808D" />
          <span>builders</span>
        </div>
        {appTabs.map((tab) => <span class="hero-app-tab">{tab}</span>)}
      </div>
      <div class="hero-app-body">
        <div class="hero-app-side">
          <span>Artefatos de Antônio</span>
        </div>
        <div class="hero-app-main">
          <span class="hero-app-title">Constructor</span>
          <span class="hero-app-sub">Converse sobre qualquer aspecto da sua empresa.</span>
          <div class="hero-app-bubble" style="height:42px"></div>
          <span class="hero-app-q">Como eu posso aumentar o faturamento da minha empresa?</span>
          <div class="hero-app-bubble" style="height:48px"></div>
          <div class="hero-app-input"></div>
        </div>
      </div>
    </div>

    <!-- Recorte do Rio: paisagem na frente; o app surge atrás dos morros -->
    <img
      class="hero-rio"
      src="/rio-recorte.png"
      alt="Paisagem do Rio de Janeiro"
      width="1600"
      height="900"
    />
  </div>

  <!-- Listras de transição pro fundo claro -->
  <div class="hero-stripes" aria-hidden="true"></div>

  <!-- Headline secundária + CTAs abaixo da imagem -->
  <div class="hero-pitch">
    <div class="hero-pitch-left">
      <img
        src="/group-35.png"
        alt="builders — AI-Powered Services as Software"
        width="340"
        height="200"
      />
    </div>
    <div class="hero-pitch-right">
      <p>
        A gente constrói e cuida do digital do seu negócio — site, automação e uma
        IA pro que o seu digital precisar.
      </p>
      <div class="hero-pitch-actions">
        <a class="btn btn-primary" href="#contato">Agende uma conversa</a>
        <a class="btn btn-outline" href="#builders-app">Conhecer a plataforma</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-paper-white);
  }
  /* Altura controlada pelo viewport, não pela imagem — evita o vão gigante */
  .hero-scene {
    position: relative;
    overflow: hidden;
    /* Altura fixa: previsível em qualquer monitor (vh deixava a cena curta
       em telas mais baixas e o app subia por cima da headline).
       App e morro ancorados na base sobem juntos quando esta altura diminui. */
    min-height: 700px;
    background: linear-gradient(
      to bottom,
      #2e93d2 0%,
      #6fb1e0 46%,
      #a9cbe5 74%,
      #bcd7eb 100%
    );
  }

  /* Headline em fluxo: respiro do menu fixo no topo, centralizada */
  .hero-intro {
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: center;
    text-align: center;
    padding: 130px 32px 0;
  }
  .hero-headline {
    margin: 0;
    max-width: 640px;
    font-weight: 700;
    font-size: 52px;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-paper-white);
  }
  .hero-accent {
    color: var(--color-paper-white);
  }

  /* Paisagem do Rio empurrada pra baixo (bottom negativo): os morros descem,
     revelando mais corpo do app acima deles (o app "emerge" mais), sem mexer
     no topo do app — então ele continua sem encostar na frase. */
  .hero-rio {
    position: absolute;
    left: 50%;
    bottom: -80px;
    transform: translateX(-50%);
    width: 100%;
    min-width: 1180px;
    height: auto;
    z-index: 2;
    pointer-events: none;
    filter: saturate(1) contrast(1.02) brightness(1.02);
  }

  /* App: maior, centralizado, ancorado na base, atrás da paisagem */
  .hero-app {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    z-index: 1;
    width: min(600px, 58%);
    /* Altura menor → topo do app desce, ficando abaixo da headline.
       Com a cena em 740px, o topo do app fica ~390px (abaixo da frase). */
    height: 350px;
    display: flex;
    flex-direction: column;
    border-radius: 14px 14px 0 0;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.64);
    backdrop-filter: blur(30px) saturate(170%);
    -webkit-backdrop-filter: blur(30px) saturate(170%);
    box-shadow:
      0 24px 80px rgba(9, 23, 23, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-bottom: none;
  }

  /* Barra de abas: agrupada à esquerda, contida na janela */
  .hero-app-tabs {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 10px 16px;
    border-bottom: 1px solid rgba(228, 227, 212, 0.6);
    background: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
  }
  .hero-app-brand {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .hero-app-brand span {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-off-black);
  }
  .hero-app-tab {
    font-size: 11px;
    color: var(--color-peacock);
    white-space: nowrap;
  }

  .hero-app-body {
    display: flex;
    flex: 1;
    min-height: 0;
  }
  .hero-app-side {
    width: 36%;
    border-right: 1px solid var(--color-ecru);
    padding: 16px;
  }
  .hero-app-side span {
    font-size: 11px;
    font-weight: 500;
    color: var(--color-off-black);
  }
  .hero-app-main {
    width: 64%;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .hero-app-title {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-off-black);
  }
  .hero-app-sub,
  .hero-app-q {
    font-size: 11px;
    line-height: 1.45;
    color: var(--color-peacock);
  }
  .hero-app-bubble {
    border-radius: 8px;
    background: rgba(32, 128, 141, 0.1);
  }
  .hero-app-input {
    margin-top: auto;
    height: 28px;
    border-radius: 6px;
    border: 1px solid var(--color-ecru);
    background: #fff;
  }

  .hero-stripes {
    width: 100%;
    height: 80px;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      rgba(46, 94, 90, 0.5) 0,
      rgba(46, 94, 90, 0.5) 2px,
      transparent 2px,
      transparent 11px
    );
    -webkit-mask-image: linear-gradient(to bottom, #000, transparent);
    mask-image: linear-gradient(to bottom, #000, transparent);
  }

  .hero-pitch {
    display: flex;
    gap: 48px;
    align-items: flex-start;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 40px 48px 0;
  }
  .hero-pitch-left {
    flex: 1;
    display: flex;
  }
  .hero-pitch-left img {
    width: 100%;
    max-width: 340px;
    height: auto;
  }
  .hero-pitch-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: 6px;
  }
  .hero-pitch-right p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-peacock);
    margin: 0;
  }
  .hero-pitch-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* Tablet */
  @media (max-width: 860px) {
    .hero-scene {
      min-height: 620px;
    }
    .hero-intro {
      padding-top: 116px;
    }
    .hero-headline {
      font-size: 38px;
    }
    .hero-app {
      width: min(440px, 78%);
      height: 320px;
    }
  }

  /* Mobile */
  @media (max-width: 560px) {
    .hero-headline {
      font-size: 29px;
    }
    .hero-app {
      width: 86%;
      height: 300px;
    }
    .hero-pitch {
      flex-direction: column;
      gap: 24px;
    }
  }
</style>
