---
// Cabeçalho global — pílula de vidro flutuante, fixa no topo.
// Navegação vem de consts.ts: muda lá e reflete em todas as páginas.
import { NAV_LINKS } from "../consts";
import BrandIcon from "./BrandIcon.astro";
---

<header class="site-header">
  <nav class="nav-pill" aria-label="Navegação principal">
    <a class="brand" href="/" aria-label="builders — página inicial">
      <BrandIcon size={18} color="#091717" />
      <span class="brand-name">builders</span>
    </a>

    <ul class="nav-links">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))
      }
    </ul>

    <div class="nav-actions">
      <a class="nav-login" href="#entrar">Entrar</a>
      <a class="btn btn-primary btn-pill nav-cta" href="#contato">Agende uma conversa</a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    /* Absolute (não sticky): a navbar flutua sobre o hero, então o céu azul
       começa no topo da página — sem faixa branca antes da imagem. */
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 18px 16px 0;
    pointer-events: none;
  }
  .nav-pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    max-width: 1010px;
    margin: 0 auto;
    padding: 10px 14px 10px 22px;
    border-radius: 16px;
    background: rgba(251, 250, 244, 0.65);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 8px 30px rgba(9, 23, 23, 0.12);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand-name {
    font-size: 14px;
    font-weight: 300;
    color: var(--color-off-black);
  }
  .nav-links {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-links a {
    font-size: 13px;
    color: var(--color-off-black);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-links a:hover {
    color: var(--color-turquoise);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }
  .nav-login {
    font-size: 13px;
    color: var(--color-off-black);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-cta {
    font-size: 13px;
    padding: 9px 18px;
  }

  /* Mobile: foca em marca + CTA, esconde a navegação central e o login.
     Mantém o header leve sem precisar de JavaScript. */
  @media (max-width: 860px) {
    .nav-links,
    .nav-login {
      display: none;
    }
  }
</style>
