---
// Scripts de tracking/pixel centralizados num componente só.
// Muda aqui (ou nas env vars) e reflete em todas as páginas.
//
// Nada é carregado enquanto os IDs não forem definidos — site continua leve.
// Para ativar, defina na Vercel (ou em .env):
//   PUBLIC_GA_ID      → Google Analytics 4 (ex: G-XXXXXXX)
//   PUBLIC_META_PIXEL → Meta/Facebook Pixel (ex: 1234567890)
const GA_ID = import.meta.env.PUBLIC_GA_ID;
const META_PIXEL = import.meta.env.PUBLIC_META_PIXEL;
---

{
  /* Google Analytics 4 — só carrega se o ID estiver definido */
  GA_ID && (
    <>
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
      />
      <script is:inline define:vars={{ GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag("js", new Date());
        gtag("config", GA_ID);
      </script>
    </>
  )
}

{
  /* Meta Pixel — só carrega se o ID estiver definido */
  META_PIXEL && (
    <script is:inline define:vars={{ META_PIXEL }}>
      {`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', META_PIXEL); fbq('track', 'PageView');`}
    </script>
  )
}
