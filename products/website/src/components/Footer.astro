---
// Rodapé global — navegação de consts.ts e ano dinâmico.
// Muda num lugar só e reflete em todas as páginas.
import { NAV_LINKS, SITE } from "../consts";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <span class="footer-brand">builders</span>
    <nav class="footer-nav" aria-label="Rodapé">
      {NAV_LINKS.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <span class="footer-copy">© {year} {SITE.legalName}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-off-black);
    padding: 48px;
    border-top: 1px solid var(--color-inky-blue);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-brand {
    font-size: 13px;
    font-weight: 300;
    color: var(--color-paper-white);
  }
  .footer-nav {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-size: 12px;
    color: #7aada8;
    text-decoration: none;
  }
  .footer-nav a:hover {
    color: var(--color-paper-white);
  }
  .footer-copy {
    font-size: 12px;
    color: var(--color-peacock);
  }
</style>
