---
// Layout base de todas as páginas: estrutura HTML, <head> de SEO, tracking,
// cabeçalho, rodapé e (opcional) pop-up. Cada página só preenche o conteúdo.
import { SITE } from "../consts";
import BaseHead from "../components/BaseHead.astro";
import Tracking from "../components/Tracking.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, image, type, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <Tracking />
  </head>
  <body>
    <a class="skip-link" href="#main">Pular para o conteúdo</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <slot name="overlays" />
  </body>
</html>
