---
// Layout base de todas as páginas: estrutura HTML, <head> de SEO, tracking,
// cabeçalho, rodapé e (opcional) pop-up. Cada página só preenche o conteúdo.
import { SITE } from "../consts";
import BaseHead from "../components/BaseHead.astro";
import Tracking from "../components/Tracking.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, image, type, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
    <Tracking />
  </head>
  <body>
    <a class="skip-link" href="#main">Pular para o conteúdo</a>
    <!-- Film esverdeado global (atmosfera tech) — só visual, não interativo -->
    <div class="site-film" aria-hidden="true"></div>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <slot name="overlays" />

    <!-- Reveal no scroll (feel intercom). is:inline = não passa pelo bundler.
         Marca <html> com has-reveal só quando o JS roda; sem JS nada some. -->
    <script is:inline>
      (function () {
        var root = document.documentElement;
        if (!("IntersectionObserver" in window)) return;
        root.classList.add("has-reveal");
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add("in-view");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        var run = function () {
          document
            .querySelectorAll("main > section:not(.hero)")
            .forEach(function (s) { io.observe(s); });
        };
        if (document.readyState !== "loading") run();
        else document.addEventListener("DOMContentLoaded", run);
      })();
    </script>
  </body>
</html>
